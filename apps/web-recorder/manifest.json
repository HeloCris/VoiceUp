{
  "manifest_version": 3,
  "name": "VoiceUp",
  "version": "0.1.0",
  "description": "Transforma o Google Classroom em um laboratório de idiomas inteligente, automatizando gravações e avaliações.",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "public/icone.png",
      "48": "public/icone.png",
      "128": "public/icone.png"
    }
  },
  "icons": {
    "16": "public/icone.png",
    "48": "public/icone.png",
    "128": "public/icone.png"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://classroom.google.com/*",
    "https://*.googleusercontent.com/*",
    "http://localhost:5174/*",
    "http://localhost:8080/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "voiceup@github.com",
      "strict_min_version": "115.0"
    }
  }
}
