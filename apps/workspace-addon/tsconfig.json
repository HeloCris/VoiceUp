{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "rootDir": "src",
    "outDir": "dist",
    "lib": ["ES2020"],
    "strict": true,
    "noImplicitAny": true,
    "moduleResolution": "Node16",
    "typeRoots": ["./node_modules/@types"],
    "types": ["google-apps-script"]
  },
  "include": ["src/**/*"]
}
